+//////////////////////////////////////////////////////////////////////////////
+// support for interrupt attribute
+
+static tree mn10300_handle_interrupt_attribute (tree *, tree, tree, int, bool *);
+
+static const struct attribute_spec mn10300_attribute_table[] = {
+  /* { name, min, max, decl_req, type_req, fn_type_req, handler, affects_type_identity } */
+  { "interrupt", 0, 0, true, false,  false,  mn10300_handle_interrupt_attribute, false },
+  { NULL,        0, 0, false, false, false, NULL, false }
+};
+
+/* Handle an "interrupt" attribute; arguments as in
+   struct attribute_spec.handler.  */
+static tree
+mn10300_handle_interrupt_attribute (tree *node, tree name, tree args,
+                                   int flags, bool *no_add_attrs)
+{
+  tree decl = *node;
+
+  /* The interrupt attribute only applies to functions.  */
+  if (TREE_CODE (decl) != FUNCTION_DECL)
+    {
+      warning (OPT_Wattributes, "%qE attribute only applies to functions", name);
+      *no_add_attrs = true;
+    }
+  /* The interrupt attribute for MN10300 does not take arguments.  */
+  else if (args != NULL_TREE)
+    {
+      error ("%qE attribute does not take any arguments", name);
+      *no_add_attrs = true;
+    }
+
+  return NULL_TREE;
+}
+
+static bool
+mn10300_is_interrupt_func (void)
+{
+  return (lookup_attribute ("interrupt",
+                           DECL_ATTRIBUTES (current_function_decl))
+          != NULL_TREE);
+}
